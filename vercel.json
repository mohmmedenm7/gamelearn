{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "build",
    "framework": "create-react-app",
    "routes": [
        {
            "src": "/static/(.*)",
            "headers": {
                "Cache-Control": "public, max-age=31536000, immutable"
            },
            "dest": "/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}